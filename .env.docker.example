NODE_ENV=development
QUIZMIND_RUNTIME_MODE=connected
API_HOST_PORT=4000
WEB_HOST_PORT=3000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
API_URL=http://localhost:4000
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
TRUST_PROXY_HOPS=0

# ── Database credentials ────────────────────────────────────────────────────
# PRODUCTION: set all four to the same credentials. POSTGRES_PASSWORD must
# match whatever password was used when the Postgres data volume was first
# initialised. Changing it here alone does NOT update the stored role — see
# docs/deployment.md "Database Credential Management" if they have drifted.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quizmind
# DATABASE_URL must use the same user/password as above.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/quizmind

REDIS_URL=redis://redis:6379
QUIZMIND_EXTENSION_BIND_CODE_STORE_MODE=optional
QUIZMIND_EXTENSION_STRICT_PLATFORM_ORIGIN=false
# Comma-separated Chrome/Firefox extension origins allowed to call the API (production-safe, no wildcards)
# Example: ALLOWED_EXTENSION_ORIGINS=chrome-extension://miccididebbhdkfbjaebbkaainbgpmkg
ALLOWED_EXTENSION_ORIGINS=
JWT_SECRET=change-me-in-docker
JWT_REFRESH_SECRET=change-me-refresh-in-docker
EMAIL_PROVIDER=noop
EMAIL_FROM=noreply@quizmind.local
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=QuizMind Platform
OPENROUTER_TIMEOUT_MS=45000
POLZA_API_URL=https://api.polza.ai/v1
POLZA_API_KEY=
POLZA_TIMEOUT_MS=45000
S3_BUCKET=
S3_ENDPOINT=
# Optional: bootstrap the first admin on initial deploy (one-time only, safe to leave set).
# If an admin already exists these vars are ignored. Never reaches client code.
# ADMIN_BOOTSTRAP_EMAIL=
# ADMIN_BOOTSTRAP_PASSWORD=
# ADMIN_BOOTSTRAP_NAME=
