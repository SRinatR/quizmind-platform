{
  "name": "quizmind-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "corepack pnpm -r --stream run build",
    "dev": "corepack pnpm -r --parallel --stream --filter ./apps/* run dev",
    "lint": "corepack pnpm -r --stream run lint",
    "typecheck": "corepack pnpm -r --stream run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,css}\""
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
