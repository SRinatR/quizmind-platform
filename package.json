{
  "name": "quizmind-platform",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @quizmind/api --filter @quizmind/web --filter @quizmind/worker --parallel run dev",
    "build": "corepack pnpm -r --if-present run build",
    "lint": "corepack pnpm -r --workspace-concurrency=1 --if-present run lint",
    "typecheck": "corepack pnpm -r --if-present run typecheck",
    "test": "node --import tsx --test \"packages/*/test/**/*.test.ts\" \"apps/*/test/**/*.test.ts\""
  }
}
