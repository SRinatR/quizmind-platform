NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000
DEFAULT_PERSONA=platform-admin

# Comma-separated list of email addresses that get full admin UI access.
