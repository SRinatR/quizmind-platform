NODE_ENV=development
QUIZMIND_RUNTIME_MODE=mock
API_URL=http://localhost:4000
APP_URL=http://localhost:3000
API_PORT=4000
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quizmind
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ISSUER=http://localhost:4000
JWT_AUDIENCE=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
EMAIL_PROVIDER=noop
EMAIL_FROM=noreply@quizmind.local
BILLING_PROVIDER=mock
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=QuizMind Platform
OPENROUTER_TIMEOUT_MS=45000
S3_BUCKET=
S3_ENDPOINT=
