{
  "title": "API — Requests / Latency / Errors",
  "uid": "quizmind-api",
  "tags": ["quizmind", "api"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(quizmind_api_http_requests_total[1m])) by (status_class)",
          "legendFormat": "{{ status_class }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "5xx Error Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(quizmind_api_http_5xx_total[1m])) by (route)",
          "legendFormat": "{{ route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "p50 / p95 / p99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(quizmind_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(quizmind_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(quizmind_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Requests by Route (top 10)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(quizmind_api_http_requests_total[5m])) by (route))",
          "legendFormat": "{{ route }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5,
      "title": "AI Proxy Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(quizmind_api_ai_proxy_requests_total[5m])) by (outcome)",
          "legendFormat": "{{ outcome }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "title": "API Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "quizmind_api_process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS MB"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MB" } }
    },
    {
      "id": 7,
      "title": "API Node.js Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(quizmind_api_nodejs_eventloop_lag_seconds_sum[1m]) / rate(quizmind_api_nodejs_eventloop_lag_seconds_count[1m]) * 1000",
          "legendFormat": "avg lag ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ]
}
