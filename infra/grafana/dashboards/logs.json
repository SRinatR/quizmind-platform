{
  "title": "Container Logs",
  "uid": "quizmind-logs",
  "tags": ["quizmind", "logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "uid": "loki" },
        "query": "label_values(container)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Logs — $container",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 20 },
      "datasource": { "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"$container\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 2,
      "title": "Log Volume",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "datasource": { "uid": "loki" },
      "targets": [
        {
          "expr": "sum(rate({container=~\"$container\"}[1m])) by (container)",
          "legendFormat": "{{ container }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
