{
  "title": "Worker — Queue & Job Activity",
  "uid": "quizmind-worker",
  "tags": ["quizmind", "worker"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Processed / s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(quizmind_worker_jobs_processed_total[5m])) by (queue)",
          "legendFormat": "{{ queue }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 2,
      "title": "Jobs Failed / s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(quizmind_worker_jobs_failed_total[5m])) by (queue)",
          "legendFormat": "{{ queue }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Jobs Processed (all time)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 5 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(quizmind_worker_jobs_processed_total)",
          "legendFormat": "Total Processed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "Total Jobs Failed (all time)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 5 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(quizmind_worker_jobs_failed_total)",
          "legendFormat": "Total Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "History Cleanup Runs & Deletes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 5 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(quizmind_worker_history_cleanup_runs_total[30m])",
          "legendFormat": "cleanup runs/30m"
        },
        {
          "expr": "rate(quizmind_worker_history_cleanup_deleted_total[30m])",
          "legendFormat": "records deleted/30m"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Worker Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "quizmind_worker_process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS MB"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MB" } }
    },
    {
      "id": 7,
      "title": "Failure Rate per Queue (%)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(quizmind_worker_jobs_failed_total[30m])) by (queue) / (sum(rate(quizmind_worker_jobs_processed_total[30m])) by (queue) + sum(rate(quizmind_worker_jobs_failed_total[30m])) by (queue)) * 100",
          "legendFormat": "{{ queue }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    }
  ]
}
