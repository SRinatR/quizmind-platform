{
  "title": "VPS & Container Overview",
  "uid": "quizmind-overview",
  "tags": ["quizmind", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 88 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Disk Usage % (/)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "Disk %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Network I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "RX {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "TX {{ device }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 5,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"quizmind.*\",name!=\"\"}[5m]) * 100",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 6,
      "title": "Container Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"quizmind.*\",name!=\"\"} / 1024 / 1024",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MB" } }
    }
  ]
}
