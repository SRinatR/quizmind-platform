generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  super_admin
  platform_admin
  billing_admin
  support_admin
  security_admin
  ops_admin
  content_admin
}

enum WorkspaceRole {
  workspace_owner
  workspace_admin
  workspace_billing_manager
  workspace_security_manager
  workspace_manager
  workspace_analyst
  workspace_member
  workspace_viewer
}

enum WalletTopUpStatus {
  pending
  succeeded
  canceled
  refunded
}

enum WalletLedgerEntryType {
  topup
  refund
  manual_adjustment
  usage_debit
}

enum FeatureFlagStatus {
  draft
  active
  paused
  archived
}

enum RemoteConfigScope {
  global
  environment
  plan
  workspace
  user
  extension_version
  flag
}

enum CompatibilityStatus {
  supported
  supported_with_warnings
  deprecated
  unsupported
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum EventSeverity {
  debug
  info
  warn
  error
}

enum CredentialOwnerType {
  platform
  workspace
  user
}

enum CredentialValidationStatus {
  pending
  valid
  invalid
  revoked
}

enum AiProviderPolicyScopeType {
  global
  workspace
}

enum AiAccessPolicyMode {
  platform_only
  user_key_optional
  user_key_required
  admin_approved_user_key
  enterprise_managed
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String?
  emailVerifiedAt        DateTime?
  displayName            String?
  avatarUrl              String?
  timezone               String?
  locale                 String?
  uiPreferences          Json?
  suspendedAt            DateTime?
  suspendReason          String?
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  sessions               Session[]
  emailVerifications     EmailVerification[]
  passwordResets         PasswordReset[]
  systemRoleAssignments  UserSystemRole[]
  memberships            WorkspaceMembership[]
  featureFlagOverrides   FeatureFlagOverride[]
  remoteConfigVersions   RemoteConfigVersion[]   @relation("RemoteConfigPublishedBy")
  extensionInstallations ExtensionInstallation[]
  extensionInstallationSessions ExtensionInstallationSession[]
  providerCredentials    ProviderCredential[]
  aiRequests             AiRequest[]
  aiProviderPoliciesUpdated AiProviderPolicy[]  @relation("AiProviderPolicyUpdatedBy")
  supportTickets         SupportTicket[]         @relation("SupportTicketRequester")
  assignedSupportTickets SupportTicket[]         @relation("SupportTicketAssignee")
  supportTicketPresetFavorites SupportTicketPresetFavorite[]
  supportImpersonationSessionsStarted SupportImpersonationSession[] @relation("SupportImpersonationActor")
  supportImpersonationSessionsTargeted SupportImpersonationSession[] @relation("SupportImpersonationTarget")
  wallet                               Wallet?
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  ipAddress  String?
  userAgent  String?
  browser    String?
  deviceName String?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id                     String                  @id @default(cuid())
  slug                   String                  @unique
  name                   String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  memberships            WorkspaceMembership[]
  invitations            WorkspaceInvite[]
  featureFlagOverrides   FeatureFlagOverride[]
  supportTickets         SupportTicket[]
  aiRequests             AiRequest[]
}

model Wallet {
  id             String              @id @default(cuid())
  userId         String              @unique
  currency       String              @default("RUB")
  balanceKopecks Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  topUps         WalletTopUp[]
  ledgerEntries  WalletLedgerEntry[]
}

model WalletTopUp {
  id                String            @id @default(cuid())
  walletId          String
  createdByUserId   String
  amountKopecks     Int
  currency          String            @default("RUB")
  status            WalletTopUpStatus @default(pending)
  provider          String            @default("yookassa")
  providerPaymentId String?           @unique
  idempotenceKey    String            @unique
  metadataJson      Json?
  confirmationToken String?
  paidAt            DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  wallet            Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  ledgerEntries     WalletLedgerEntry[]
}

model WalletLedgerEntry {
  id                  String                @id @default(cuid())
  walletId            String
  topUpId             String?
  type                WalletLedgerEntryType
  deltaKopecks        Int
  balanceAfterKopecks Int
  description         String?
  createdAt           DateTime              @default(now())
  wallet              Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  topUp               WalletTopUp?          @relation(fields: [topUpId], references: [id], onDelete: SetNull)
}

model WorkspaceMembership {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole
  tokenHash   String        @unique
  expiresAt   DateTime
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UserSystemRole {
  id        String     @id @default(cuid())
  userId    String
  role      SystemRole
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model WebhookEvent {
  id                String   @id @default(cuid())
  provider          String
  externalEventId   String
  eventType         String
  status            String
  payloadJson       Json
  providerCreatedAt DateTime?
  processedAt       DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  receivedAt        DateTime @default(now())

  @@unique([provider, externalEventId])
  @@index([provider, status, receivedAt])
}

model QuotaCounter {
  id          String   @id @default(cuid())
  key         String
  consumed    Int      @default(0)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, periodStart, periodEnd])
}

model AiRequest {
  id                 String     @id @default(cuid())
  userId             String
  workspaceId        String?
  installationId     String?
  provider           String
  model              String
  promptTokens       Int        @default(0)
  completionTokens   Int        @default(0)
  totalTokens        Int        @default(0)
  keySource          String     @default("platform")
  status             String     @default("success")
  errorCode          String?
  durationMs         Int?
  requestMetadata    Json?
  requestType        String?
  fileMetadataJson   Json?
  estimatedCostUsd   Float?
  expiresAt          DateTime?
  occurredAt         DateTime   @default(now())
  createdAt          DateTime   @default(now())
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([occurredAt])
  @@index([expiresAt])
  @@map("ai_requests")
}

model FeatureFlag {
  id                      String                @id @default(cuid())
  key                     String                @unique
  description             String
  status                  FeatureFlagStatus
  enabled                 Boolean               @default(false)
  rolloutPercentage       Int?
  allowRolesJson          Json?
  minimumExtensionVersion String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  overrides               FeatureFlagOverride[]
}

model FeatureFlagOverride {
  id            String      @id @default(cuid())
  featureFlagId String
  userId        String?
  workspaceId   String?
  enabled       Boolean
  createdAt     DateTime    @default(now())
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RemoteConfigVersion {
  id            String              @id @default(cuid())
  publishedById String?
  versionLabel  String
  isActive      Boolean             @default(false)
  createdAt     DateTime            @default(now())
  publishedBy   User?               @relation("RemoteConfigPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  layers        RemoteConfigLayer[]
}

model RemoteConfigLayer {
  id                    String              @id @default(cuid())
  remoteConfigVersionId String
  scope                 RemoteConfigScope
  priority              Int
  conditionsJson        Json?
  valuesJson            Json
  createdAt             DateTime            @default(now())
  remoteConfigVersion   RemoteConfigVersion @relation(fields: [remoteConfigVersionId], references: [id], onDelete: Cascade)
}

model ExtensionCompatibilityRule {
  id                      String              @id @default(cuid())
  minimumVersion          String
  recommendedVersion      String
  supportedSchemaVersions Json
  requiredCapabilities    Json?
  resultStatus            CompatibilityStatus
  reason                  String?
  createdAt               DateTime            @default(now())
}

model ExtensionInstallation {
  id               String               @id @default(cuid())
  userId           String
  installationId   String               @unique
  browser          String
  extensionVersion String
  schemaVersion    String
  capabilitiesJson Json
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  lastSeenAt       DateTime?
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  telemetry        ExtensionTelemetry[]
  sessions         ExtensionInstallationSession[]
}

model ExtensionInstallationSession {
  id                      String                @id @default(cuid())
  extensionInstallationId String
  userId                  String
  tokenHash               String                @unique
  expiresAt               DateTime
  createdAt               DateTime              @default(now())
  revokedAt               DateTime?
  installation            ExtensionInstallation @relation(fields: [extensionInstallationId], references: [id], onDelete: Cascade)
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderCredential {
  id                String                     @id @default(cuid())
  provider          String
  ownerType         CredentialOwnerType
  ownerId           String?
  userId            String?
  encryptedSecretJson Json
  validationStatus  CredentialValidationStatus @default(pending)
  scopesJson        Json?
  metadataJson      Json?
  lastValidatedAt   DateTime?
  disabledAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  user              User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([provider, ownerType, createdAt])
}

model AiProviderPolicy {
  id                              String                    @id @default(cuid())
  scopeKey                        String                    @unique
  scopeType                       AiProviderPolicyScopeType
  mode                            AiAccessPolicyMode
  allowPlatformManaged            Boolean                   @default(true)
  allowBringYourOwnKey            Boolean                   @default(false)
  allowDirectProviderMode         Boolean                   @default(false)
  allowWorkspaceSharedCredentials Boolean                   @default(false)
  requireAdminApproval            Boolean                   @default(false)
  allowVisionOnUserKeys           Boolean                   @default(false)
  providersJson                   Json
  allowedModelTagsJson            Json?
  defaultProvider                 String?
  defaultModel                    String?
  reason                          String?
  updatedById                     String?
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt
  updatedBy                       User?                     @relation("AiProviderPolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([scopeType])
}

model ExtensionTelemetry {
  id                      String                @id @default(cuid())
  extensionInstallationId String
  eventType               String
  severity                EventSeverity
  payloadJson             Json?
  createdAt               DateTime              @default(now())
  installation            ExtensionInstallation @relation(fields: [extensionInstallationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  targetType   String
  targetId     String
  metadataJson Json?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id           String   @id @default(cuid())
  actorId      String?
  eventType    String
  metadataJson Json?
  createdAt    DateTime @default(now())
}

model SecurityEvent {
  id           String        @id @default(cuid())
  actorId      String?
  eventType    String
  severity     EventSeverity
  metadataJson Json?
  createdAt    DateTime      @default(now())
}

model DomainEvent {
  id          String   @id @default(cuid())
  eventType   String
  payloadJson Json?
  createdAt   DateTime @default(now())
}

model SupportTicket {
  id          String       @id @default(cuid())
  workspaceId String?
  requesterId String
  assignedToId String?
  subject     String
  body        String
  status      TicketStatus @default(open)
  handoffNote String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  requester   User         @relation("SupportTicketRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedTo  User?        @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  impersonationSessions SupportImpersonationSession[]

  @@index([status, updatedAt])
  @@index([assignedToId, updatedAt])
}

model SupportTicketPresetFavorite {
  id        String   @id @default(cuid())
  userId    String
  presetKey String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, presetKey])
  @@index([userId, createdAt])
}

model SupportImpersonationSession {
  id             String     @id @default(cuid())
  supportActorId String
  targetUserId   String
  supportTicketId String?
  reason         String
  operatorNote   String?
  closeReason    String?
  createdAt      DateTime   @default(now())
  endedAt        DateTime?
  supportTicket  SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: SetNull)
  supportActor   User       @relation("SupportImpersonationActor", fields: [supportActorId], references: [id], onDelete: Cascade)
  targetUser     User       @relation("SupportImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([supportActorId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([supportTicketId, createdAt])
}
